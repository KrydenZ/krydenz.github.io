{
    "name": "krydenz.github.io",
    "title": "krydenz Blog",
    "author": "krydenz",
    "version": "1.7.0",
    "homepage": "https://krydenz.github.io",
    "repository": {
        "type": "git",
        "url": "https://github.com/krydenz/krydenz.github.io"
    },
    "bugs": "https://github.com/krydenz/krydenz.github.io/issues",
    "engines": {
        "node": ">=18",
        "npm": ">=9"
    },
    "devDependencies": {
        "grunt": "1.6.2",
        "grunt-banner": "0.6.0",
        "grunt-cli": "1.5.0",
        "grunt-contrib-less": "2.1.0",
        "grunt-contrib-uglify": "5.2.2",
        "grunt-contrib-watch": "1.1.0"
    },
    "scripts": {
        "build:assets": "grunt",
        "build:site": "bundle exec jekyll build",
        "build": "npm run build:assets && npm run build:site",
        "serve": "bundle exec jekyll serve --watch",
        "preview": "python -m http.server 8020 --directory _site",
        "preview:python3": "python3 -m http.server 8020 --directory _site",
        "watch:assets": "grunt watch",
        "push": "git push origin master --tag"
    }
}
